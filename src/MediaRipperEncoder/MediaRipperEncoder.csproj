<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- .NET Framework 4.8: required for Windows 7 SP1+ support and best Wine compatibility. -->
    <TargetFramework>net48</TargetFramework>
    <UseWindowsForms>true</UseWindowsForms>
    <!-- x64 primary target per project spec. -->
    <PlatformTarget>x64</PlatformTarget>
    <RootNamespace>MediaRipperEncoder</RootNamespace>
    <!-- The binary is named AutoRipper.exe (what users see installed/running); the internal
         namespaces keep the original MediaRipperEncoder name — invisible to end users and not
         worth a repo-wide rename. -->
    <AssemblyName>AutoRipper</AssemblyName>
    <Product>AutoRipper</Product>
    <Version>0.3.0.1</Version>
    <Copyright>Copyright (C) 2026 James Spurgeon (heto.black@gmail.com)</Copyright>
    <!-- SPDX license identifier. Strong copyleft incl. network use — see /LICENSE. -->
    <PackageLicenseExpression>AGPL-3.0-or-later</PackageLicenseExpression>
    <!-- C# 7.3 is the newest language version fully supported on .NET Framework 4.8. -->
    <LangVersion>7.3</LangVersion>
    <!-- App icon (disc -> pipeline -> TV). Generated from tools\IconGenerator.cs — edit that
         and re-run it rather than editing the .ico directly. -->
    <ApplicationIcon>autoripper.ico</ApplicationIcon>
    <AutoGenerateBindingRedirects>true</AutoGenerateBindingRedirects>
  </PropertyGroup>

  <ItemGroup>
    <!-- Ship the AGPL license text next to the exe so the Help > About dialog can display it
         (and to satisfy the AGPL requirement that the license travel with the program). Path is
         relative to this .csproj: the repo-root LICENSE two levels up. -->
    <None Include="..\..\LICENSE" Link="LICENSE">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <ItemGroup>
    <!-- WMI access (Win32_CDROMDrive) for enumerating optical drives. Part of the .NET
         Framework, but SDK-style projects don't reference it by default. -->
    <Reference Include="System.Management" />
    <!-- HttpClient for the OMDb / TheTVDB metadata lookups (Phase 5). Part of the .NET
         Framework, but not referenced by default in SDK-style projects. -->
    <Reference Include="System.Net.Http" />
    <!-- ZipArchive for the Help > Report a problem bundle. Part of .NET Framework, but
         SDK-style projects don't reference it by default. -->
    <Reference Include="System.IO.Compression" />
    <Reference Include="System.IO.Compression.FileSystem" />
  </ItemGroup>

  <ItemGroup>
    <!-- Provides .NET Framework 4.8 reference assemblies at build time so the project
         compiles on machines without the 4.8 Developer Pack installed. Build-time only;
         nothing is shipped from this package. -->
    <PackageReference Include="Microsoft.NETFramework.ReferenceAssemblies" Version="1.0.3" PrivateAssets="all" />
    <!-- JSON settings serialization. Single self-contained DLL, rock-solid on .NET
         Framework 4.8 and old hardware; bundled with the app (no runtime download). -->
    <PackageReference Include="Newtonsoft.Json" Version="13.0.3" />
    <!-- Reads/writes embedded media tags (Title) in the finished MP4/MKV so players and
         Explorer show the episode name, not the disc label. Single managed DLL, no native
         dependencies; fine on .NET Framework 4.8 / Windows 7. -->
    <PackageReference Include="TagLibSharp" Version="2.3.0" />
    <!-- Built-in music encoding (no external tools, nothing for Defender to distrust):
         CUETools Flake = managed FLAC encoder (GPL, AGPL-compatible; the CUERipper codec);
         NAudio.Lame = managed LAME wrapper for MP3 (bundles libmp3lame DLLs into our folder). -->
    <PackageReference Include="CUETools.Codecs" Version="1.0.2" />
    <PackageReference Include="CUETools.Codecs.FLAKE" Version="1.0.5" />
    <PackageReference Include="NAudio.Core" Version="2.2.1" />
    <PackageReference Include="NAudio.Lame" Version="2.1.0" />
    <!-- Pure-managed OGG Vorbis encoder (C# port of the Xiph encoder) — for game-friendly
         .ogg output (UT2004's music player, Audiosurf, etc.). -->
    <PackageReference Include="OggVorbisEncoder" Version="1.2.2" />
    <!-- Pure-managed Opus encoder + ogg-opus container (Opus requires 48kHz, so CD audio is
         resampled with NAudio's managed resampler). -->
    <PackageReference Include="Concentus" Version="2.2.2" />
    <PackageReference Include="Concentus.Oggfile" Version="1.0.5" />
    <!-- Media Foundation wrapper: M4A/AAC and WMA use Windows' own built-in encoders. -->
    <PackageReference Include="NAudio.Wasapi" Version="2.2.1" />
    <!-- Managed TLS engine (MIT, AGPL-compatible) for the Windows 7 fallback transport:
         Win7's SChannel lacks the modern cipher suites musicbrainz.org requires, so on a
         "secure channel" failure LegacyTlsHttp redoes the request over BouncyCastle TLS
         (own ciphers, OS crypto not involved). Modern Windows never touches this path. -->
    <PackageReference Include="BouncyCastle.Cryptography" Version="2.4.0" />
  </ItemGroup>

</Project>
