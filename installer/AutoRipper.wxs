<?xml version="1.0" encoding="UTF-8"?>
<!--
  AutoRipper MSI (WiX v6). Build with installer\build-installer.ps1.

  Design requirements (from the project spec + memory notes):
   - True MSI so admins can script deployment: msiexec /i AutoRipper-x64.msi /qn
   - Fully OFFLINE: everything is embedded; nothing is fetched at install time.
   - Requires .NET Framework 4.8 (NOT 4.8.1 — unsupported on Windows Server 2019):
     registry Release >= 528040, checked as a launch condition. The refusal message
     names the OFFLINE .NET installer and where to get it, because a server OS
     often has no working Windows Update (message must not assume a desktop OS).
   - External tools (MakeMKV, HandBrakeCLI, fre:ac) are user-supplied and NEVER bundled.
-->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!-- UpgradeCode is AutoRipper's permanent identity across all versions — never change it,
       or upgrades will install side-by-side instead of replacing. -->
  <Package Name="AutoRipper"
           Manufacturer="James Spurgeon"
           Version="0.2.4.4"
           UpgradeCode="6E1B9A47-3C52-4B7A-9D8E-2F0A61C4D513"
           Language="1033"
           Scope="perMachine"
           Compressed="yes">

    <SummaryInformation Description="AutoRipper — automated disc ripping and encoding for Plex, Jellyfin, and other media servers." />

    <!-- AllowSameVersionUpgrades: Windows Installer compares only the FIRST THREE version
         fields, so a hotfix like 0.2.3.1 looks identical to 0.2.3 and would otherwise refuse
         to upgrade it. With this on, same-x.y.z installs replace each other (which also means
         an old x.y.z MSI can replace a newer x.y.z.n — always install the newest). -->
    <MajorUpgrade DowngradeErrorMessage="A newer version of AutoRipper is already installed."
                  AllowSameVersionUpgrades="yes" />
    <MediaTemplate EmbedCab="yes" />

    <!-- App icon shown in Add/Remove Programs. Shortcuts get the exe's own embedded icon. -->
    <Icon Id="AutoRipperIco" SourceFile="$(var.SrcDir)\autoripper.ico" />
    <Property Id="ARPPRODUCTICON" Value="AutoRipperIco" />

    <!-- .NET Framework 4.8 gate. NETFRAMEWORK45 holds the raw Release DWORD ("#528040" = 4.8).
         Lexicographic compare is safe: every relevant Release value is six digits. -->
    <PropertyRef Id="NETFRAMEWORK45" />
    <Launch Condition="Installed OR NETFRAMEWORK45 &gt;= &quot;#528040&quot;"
            Message="AutoRipper requires the .NET Framework 4.8 runtime, which is not installed on this machine.&#13;&#10;&#13;&#10;Download the OFFLINE installer (ndp48-x86-x64-allos-enu.exe) from:&#13;&#10;https://dotnet.microsoft.com/download/dotnet-framework/net48&#13;&#10;&#13;&#10;The offline installer works on desktop and server editions (Windows 7 SP1 through Server 2022) without needing Windows Update. Install it, then run this setup again." />

    <!-- Desktop shortcut is created by default; scripted installs can opt out with
         msiexec ... INSTALLDESKTOPSHORTCUT=0 -->
    <Property Id="INSTALLDESKTOPSHORTCUT" Value="1" />

    <!-- Record the install folder in Add/Remove Programs (InstallLocation). The app reads it
         at startup to warn when an OUTDATED loose copy is being run while a newer version is
         properly installed (the stale-shortcut trap). -->
    <SetProperty Id="ARPINSTALLLOCATION" Value="[INSTALLFOLDER]" After="CostFinalize" />

    <!-- Application files: harvested from the staged build output with a wildcard, so new
         dependencies (e.g. the music-encoder DLLs) can never be silently missing from the MSI.
         The build script stages the Release output minus debug symbols; the wildcard ships
         exactly that. LICENSE rides along (must travel with the program; shown in Help > About). -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="AutoRipper">
        <Files Include="$(var.PublishDir)\**" />

        <!-- Uninstall sweep: remove ANY file still in the install folder (a binary that was
             locked mid-uninstall, a stray log) and then the folder itself, so an uninstall can
             never leave program files behind. Found the hard way: 0.1.0's uninstall left the
             exe + DLLs when the app hadn't fully exited before msiexec's file-removal pass. -->
        <Component Id="SweepInstallFolder">
          <RegistryKey Root="HKLM" Key="Software\AutoRipper" ForceDeleteOnUninstall="yes">
            <RegistryValue Name="InstallFolderSweep" Type="integer" Value="1" KeyPath="yes" />
          </RegistryKey>
          <RemoveFile Id="SweepLeftoverFiles" Name="*" On="uninstall" />
          <RemoveFolder Id="RemoveInstallFolder" On="uninstall" />
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Start Menu shortcut. -->
    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="AppMenuFolder" Name="AutoRipper">
        <Component Id="StartMenuShortcut">
          <Shortcut Id="AppShortcut"
                    Name="AutoRipper"
                    Description="Automated disc ripping and encoding for media servers"
                    Target="[INSTALLFOLDER]AutoRipper.exe"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="RemoveAppMenuFolder" Directory="AppMenuFolder" On="uninstall" />
          <!-- Shortcuts can't be a component KeyPath; a per-user registry marker is the standard
               pattern. CRITICAL: this key must NOT be Software\AutoRipper — the in-app
               "leave nothing behind" purge deletes that tree BEFORE msiexec runs, and with its
               KeyPath gone Windows Installer decides the shortcut component "isn't installed"
               and skips removing the shortcut. That's exactly the 0.1.0 leftover-Start-menu bug.
               Software\AutoRipperSetup is owned by the MSI alone and removed on uninstall. -->
          <RegistryKey Root="HKCU" Key="Software\AutoRipperSetup" ForceDeleteOnUninstall="yes">
            <RegistryValue Name="StartMenuShortcut" Type="integer" Value="1" KeyPath="yes" />
          </RegistryKey>
        </Component>
      </Directory>
    </StandardDirectory>

    <!-- Desktop shortcut (default on; see INSTALLDESKTOPSHORTCUT above). Taskbar pinning is
         deliberately absent: Windows provides no supported way for installers to pin — users
         pin manually via right-click. -->
    <StandardDirectory Id="DesktopFolder">
      <Component Id="DesktopShortcut" Condition="INSTALLDESKTOPSHORTCUT = 1">
        <Shortcut Id="DesktopAppShortcut"
                  Name="AutoRipper"
                  Description="Automated disc ripping and encoding for media servers"
                  Target="[INSTALLFOLDER]AutoRipper.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <!-- Same rule as the Start menu marker: never Software\AutoRipper (see above). -->
        <RegistryKey Root="HKCU" Key="Software\AutoRipperSetup" ForceDeleteOnUninstall="yes">
          <RegistryValue Name="DesktopShortcut" Type="integer" Value="1" KeyPath="yes" />
        </RegistryKey>
      </Component>
    </StandardDirectory>

  </Package>
</Wix>
